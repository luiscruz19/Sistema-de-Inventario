# =============================================================================
#  Sistema de Inventario — Variables de entorno (.env)
#  Copiá este archivo a .env y ajustá los valores antes de levantar el sistema:
#      cp .env.example .env
#  NOTA: estos son valores de EJEMPLO. NO uses estos secretos en producción.
# =============================================================================

# ─── General ──────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Infraestructura (docker-compose.infra.yml) ─────────────────────────────────
# Puerto HTTP público de Traefik (entrada del sistema).
HTTP_PORT=80
# Puerto del dashboard de Traefik.
TRAEFIK_DASHBOARD_PORT=8080
# Password de root de MySQL.
DB_ROOT_PASSWORD=secret
# Puerto del host mapeado al MySQL del contenedor (para conectarte desde afuera).
DB_PORT_HOST=3307

# ─── Base de datos (microservicios de inventario) ──────────────────────────────
DB_HOST=inventario_mysql
DB_PORT=3306
DB_USER=root
DB_DIALECT=mysql
DB_NAME_CLIENTES=inventario

# ─── Autenticación inter-servicio (Basic Auth + JWT) ───────────────────────────
AUTH_BASIC_USER=inventario
AUTH_BASIC_PW=cambiar
# Clave de firma de JWT. Usá un string largo y aleatorio en producción.
SECRET_KEY=cambiar-por-un-string-largo-y-aleatorio-de-al-menos-64-caracteres-1234567890

# ─── Servicio AUTH (services/auth) ──────────────────────────────────────────────
AUTH_API_URL=http://inventario_auth
DB_HOST_AUTH=inventario_mysql
DB_PORT_AUTH=3306
DB_USER_AUTH=root
DB_ROOT_PASSWORD_AUTH=secret
DB_NAME_AUTH=inventario_auth
# Usuario administrador creado en el primer arranque.
ADMIN_EMAIL=admin@inventario.local
ADMIN_PASSWORD=Admin1234!

# ─── Envío de emails SMTP (lo maneja el servicio AUTH) ──────────────────────────
MAILER_SMTP_HOST=smtp.gmail.com
MAILER_SMTP_PORT=587
MAILER_SMTP_SECURE=false
MAILER_USER=tu@email.com
MAILER_PASSWORD=smtp_password
MAILER_FROM_EMAIL=noreply@inventario.local
MAILER_FROM_NAME=Sistema de Inventario

# ─── URLs de microservicios (las consume el backoffice) ─────────────────────────
# Nombres canónicos (uno por microservicio).
INV_MS_PRODUCTOS_URL=http://inventario_ms_productos
INV_MS_STOCK_URL=http://inventario_ms_stock
INV_MS_VENTAS_URL=http://inventario_ms_ventas
INV_MS_COMPRAS_URL=http://inventario_ms_compras
INV_MS_FACTURACION_URL=http://inventario_ms_facturacion
INV_MS_DASHBOARD_BI_URL=http://inventario_ms_dashboard-bi
INV_MS_CONTABILIDAD_URL=http://inventario_ms_contabilidad
INV_MS_TESORERIA_URL=http://inventario_ms_tesoreria
INV_MS_MARKETPLACE_URL=http://inventario_ms_marketplace

# ─── CORS / Web ─────────────────────────────────────────────────────────────────
WEB_URL=http://inventario.localhost
CORS_ALLOWED_ORIGINS=http://inventario.localhost

# ─── Integraciones AFIP/ARCA (facturación electrónica, opcional) ────────────────
ARCA_CUIT=
ARCA_PTO_VTA=1
ARCA_CERT_PEM=
ARCA_KEY_PEM=
ARCA_ENVIRONMENT=testing
ARCA_ENABLED=false
